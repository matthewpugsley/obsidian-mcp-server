# Copy this file to .env and fill in your values.
# .env is gitignored and will never be committed.

# Absolute path to your Obsidian vault
VAULT_ROOT=C:\ObsidianVaults\Main

# Absolute path to this repo on your machine (used by deploy.ps1)
MCP_SOURCE=C:\Users\you\source\repos\obsidian-mcp-server

# Absolute path to the deploy target (where Claude Desktop loads the server from)
MCP_DEST=C:\CustomSoftware\LocalMcpServer
